{
  "description": "goal-kick: keep the goal-watching daemon alive on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-poller.sh"
          }
        ]
      }
    ]
  }
}
