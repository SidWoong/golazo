{
  "description": "golazo: keep the goal-watching daemon alive on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/plugin/scripts/ensure-poller.sh"
          }
        ]
      }
    ]
  }
}
